        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "scope": "constant.character",
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "scope": "entity.name.label",
      "settings": {
        // "foreground": "#C8C8C8"
        "foreground": "#98DCFE"
      }
    },
    {
      "name": "Control flow / Special keywords",
