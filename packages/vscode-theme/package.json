{
  "name": "rajzik-theme",
  "displayName": "Rajzik theme",
  "version": "1.0.3",
  "description": "A dark theme for Visual Studio Code",
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "themes"
  ],
  "homepage": "https://github.com/rajzik/vs-code-theme",
  "bugs": {
    "url": "https://github.com/rajzik/vs-code-theme/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Rajzik"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rajzik/vs-code-theme.git"
  },
  "qna": "https://github.com/rajzik/vs-code-theme/issues",
  "publisher": "rajzik",
  "files": [
    "assets",
    "themes",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "format": "oxfmt --no-error-on-unmatched-pattern",
    "package": "mkdir -p dist && vsce package --out dist/rajzik-theme.vsix",
    "release": "pnpm run package"
  },
  "devDependencies": {
    "@vscode/vsce": "3.8.1",
    "ovsx": "0.10.11"
  },
  "contributes": {
    "themes": [
      {
        "id": "rajzik-dark",
        "label": "Rajzik Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/rajzik_dark.json"
      }
    ]
  },
  "icon": "assets/rajzik-logo.png",
  "preview": false,
  "engines": {
    "vscode": "^1.100.0"
  }
}
