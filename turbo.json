{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "format": {
      "cache": false
    },
    "format:fix": {
      "cache": false
    },
    "package": {
      "dependsOn": ["^package"],
      "outputs": ["dist/**"]
    },
    "release": {
      "dependsOn": ["package"],
      "cache": false
    }
  }
}
