{
  "name": "vs-code-theme-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "format": "oxfmt . && turbo run format --continue",
    "format:fix": "oxfmt --write . && turbo run format --continue -- --write",
    "lint": "oxlint --type-aware --type-check",
    "package": "turbo run package",
    "release": "turbo run release",
    "test": "vitest run --dir scripts",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@rajzik/oxfmt-config": "catalog:",
    "@rajzik/oxlint-config": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "vitest": "catalog:"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": "24.14.0"
    }
  },
  "packageManager": "pnpm@10.33.1"
}
